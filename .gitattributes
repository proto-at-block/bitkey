# Git LFS tracking for Android app snapshots
app/android/**/snapshots/**/*.png filter=lfs diff=lfs merge=lfs -text

# SQL file syntax highlighting
app/**/*.sq linguist-language=sql
app/**/*.sqm linguist-language=sql

# Git LFS tracking for Rust bdk-ffi libraries
app/rust/bdk-ffi/libs/**/*.a filter=lfs diff=lfs merge=lfs -text
app/rust/bdk-ffi/libs/**/*.so filter=lfs diff=lfs merge=lfs -text
app/rust/bdk-ffi/libs/**/*.dylib filter=lfs diff=lfs merge=lfs -text

# Git LFS tracking for firmware snapshot test images
firmware/test/snapshots/**/*.png filter=lfs diff=lfs merge=lfs -text
